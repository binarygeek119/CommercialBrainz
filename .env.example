# CommercialBrainz environment configuration

# Database
DATABASE_URL=postgresql+asyncpg://commercialbrainz:commercialbrainz@localhost:5432/commercialbrainz
DATABASE_URL_SYNC=postgresql://commercialbrainz:commercialbrainz@localhost:5432/commercialbrainz

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440

# Submit slots and reputation
SUBMIT_SLOTS_BASE=1
SUBMIT_SLOTS_MAX=20
SUBMIT_SLOTS_POINTS_PER_SLOT=20
REPUTATION_POINT_VALUE=0.25

# App
APP_NAME=CommercialBrainz
APP_ENV=development
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
THUMBNAIL_UPLOAD_DIR=/data/thumbnails
THUMBNAIL_MAX_BYTES=2097152
LOGO_UPLOAD_DIR=/data/logos
LOGO_MAX_BYTES=5242880
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Edit/vote settings
EDIT_OPEN_DAYS=7
EDIT_EARLY_CLOSE_VOTES=3
BRAND_EARLY_CLOSE_VOTES=10
VOTING_MIN_ACCOUNT_DAYS=14
VOTING_MIN_ACCEPTED_EDITS=10
VOTING_NO_VOTE_EXTENSION_HOURS=72

# Rate limiting (requests per second)
RATE_LIMIT_ANON=1
RATE_LIMIT_AUTH=5

# SMTP (optional — DMCA notifications and password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=commercialbrainz@outlook.com
DMCA_CONTACT=commercialbrainz@outlook.com

# GCloud (production)
GCS_DUMP_BUCKET=
GCP_PROJECT_ID=

# Internet Archive dataset export (admin task)
IA_ACCESS_KEY=
IA_SECRET_KEY=
IA_COLLECTION=commercialbrainz
ARCHIVE_EXPORT_DIR=exports/archive-org
IA_SKIP_UPLOAD=false

# HTTPS (Caddy + Let's Encrypt on VM — set DOMAIN to your DuckDNS hostname)
DOMAIN=
ACME_EMAIL=commercialbrainz@outlook.com
