# SpotBrainz environment configuration

# Database
DATABASE_URL=postgresql+asyncpg://spotbrainz:spotbrainz@localhost:5432/spotbrainz
DATABASE_URL_SYNC=postgresql://spotbrainz:spotbrainz@localhost:5432/spotbrainz

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_NAME=SpotBrainz
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Edit/vote settings
EDIT_OPEN_DAYS=7
EDIT_EARLY_CLOSE_VOTES=3
VOTING_MIN_ACCOUNT_DAYS=14
VOTING_MIN_ACCEPTED_EDITS=10
VOTING_NO_VOTE_EXTENSION_HOURS=72

# Rate limiting (requests per second)
RATE_LIMIT_ANON=1
RATE_LIMIT_AUTH=5

# SMTP (optional, for DMCA notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@spotbrainz.org
DMCA_CONTACT=dmca@spotbrainz.org

# GCloud (production)
GCS_DUMP_BUCKET=
GCP_PROJECT_ID=
