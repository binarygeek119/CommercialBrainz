# Caddy — automatic HTTPS via Let's Encrypt (HTTP-01 challenge)
# Requires DOMAIN and ACME_EMAIL in environment (.env)
# https://caddyserver.com/docs/automatic-https

{
	email {$ACME_EMAIL}
}

(commercialbrainz_proxy) {
	handle /api/* {
		reverse_proxy http://api:8000 {
			health_uri /health
			health_interval 15s
			health_timeout 5s
		}
	}
	handle /docs* {
		reverse_proxy http://api:8000 {
			health_uri /health
			health_interval 15s
			health_timeout 5s
		}
	}
	handle /redoc* {
		reverse_proxy http://api:8000 {
			health_uri /health
			health_interval 15s
			health_timeout 5s
		}
	}
	handle /openapi.json {
		reverse_proxy http://api:8000 {
			health_uri /health
			health_interval 15s
			health_timeout 5s
		}
	}
	handle /health {
		reverse_proxy http://api:8000 {
			health_uri /health
			health_interval 15s
			health_timeout 5s
		}
	}
	handle {
		reverse_proxy http://web:80
	}
}

# HTTPS for DuckDNS / custom domain (Let's Encrypt)
{$DOMAIN} {
	import commercialbrainz_proxy
}

# HTTP fallback when accessing by IP (no TLS)
:80 {
	import commercialbrainz_proxy
}
